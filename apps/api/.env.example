# apps/api — Express 5 service.
#
# All apps/api env vars except the API-specific ones below are shared with
# apps/web (same Postgres, Redis, S3, secrets). Coolify provisions both
# services with the same env file.

# Service-specific
PORT=3001
NODE_ENV=production
APP_BASE_URL=https://pilalang.example.com   # web origin (CORS allow-list, magic-link callback redirect)
LOG_LEVEL=info

# Storage / cache
DATABASE_URL=postgres://...
REDIS_URL=redis://...

# S3-compatible
S3_ENDPOINT=https://s3...
S3_BUCKET=pila-logos
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_PUBLIC_URL_BASE=https://cdn...

# Crypto secrets (32+ chars)
QR_TOKEN_SECRET=
HOST_JWT_SECRET=
GUEST_JWT_SECRET=

# Admin allow-list (comma-separated)
ADMIN_EMAILS=admin@example.com

# Reused by apps/api as the admin JWT signing key during the post-NextAuth
# cutover (Sprint 7 of the Express migration). Rename to ADMIN_JWT_SECRET
# in a follow-up once Tier-1 rollback is no longer needed.
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://pilalang.example.com

# Email
RESEND_API_KEY=re_...

# FCM (optional)
FIREBASE_SERVICE_ACCOUNT_JSON=
