# apps/web — Next.js 14 UI service. Shares secrets with apps/api.

NODE_ENV=production
PORT=3000

# Browser-side: empty in prod (Traefik routes same-origin), set to apps/api
# URL in dev so EventSource + Next rewrites both target the new service.
NEXT_PUBLIC_API_BASE_URL=

# Storage / cache (also read by Server Components doing SSR data fetches)
DATABASE_URL=postgres://...
REDIS_URL=redis://...

# S3-compatible (used for next/image remotePatterns)
S3_ENDPOINT=https://s3...
S3_BUCKET=pila-logos
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_PUBLIC_URL_BASE=https://cdn...

# Crypto secrets (must match apps/api — both verify the same JWTs)
QR_TOKEN_SECRET=
HOST_JWT_SECRET=
GUEST_JWT_SECRET=

# Admin allow-list (comma-separated)
ADMIN_EMAILS=admin@example.com

# Reused as the admin JWT verifier secret in apps/web/middleware.ts.
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://pilalang.example.com

# Web origin — same value as NEXTAUTH_URL for now. Required by the shared
# env validator so misconfigs fail fast at boot.
APP_BASE_URL=https://pilalang.example.com

RESEND_API_KEY=re_...

# Mobile / .well-known config
APP_IOS_BUNDLE_ID=com.pilalang.app
APP_ANDROID_PACKAGE_NAME=com.pilalang.app
APP_ANDROID_SHA256_FINGERPRINTS=
