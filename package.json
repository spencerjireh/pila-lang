{
  "name": "pila-lang",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "dotenv -e .env -- pnpm --filter @pila/web dev",
    "build": "turbo run build",
    "start": "pnpm --filter @pila/web start",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && turbo run typecheck",
    "db:generate": "pnpm --filter @pila/db generate",
    "db:migrate": "pnpm --filter @pila/db migrate",
    "db:studio": "dotenv -e .env -- pnpm --filter @pila/db studio",
    "seed": "tsx --env-file-if-exists=.env scripts/seed.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@pila/db": "workspace:*",
    "@pila/shared": "workspace:*",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@pila/config": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.9.3",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "dotenv-cli": "^7.4.4",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "sharp"
    ]
  }
}
