{
  "name": "pila-lang",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle/drizzle.config.ts",
    "seed": "tsx --env-file-if-exists=.env scripts/seed.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.99.0",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.36.4",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "lucide-react": "^1.8.0",
    "minio": "^8.0.7",
    "next": "^14.2.18",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.13.1",
    "qrcode.react": "^4.2.0",
    "rate-limiter-flexible": "^5.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-phone-number-input": "^3.4.16",
    "resend": "^6.12.0",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.9.3",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "sharp"
    ]
  }
}
