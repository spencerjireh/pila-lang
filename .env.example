# Pila Lang v1 environment. Copy to .env (dev) or .env.prod and fill in.

# development | test | production
NODE_ENV=development

# Postgres connection used by the app and migrator services.
DATABASE_URL=postgres://queue:queue@localhost:5432/queue

# Redis used for pub/sub, rate limits, and the undo queue.
REDIS_URL=redis://localhost:6379

# Blob storage (MinIO in dev, S3-compatible in prod).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=queue-logos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Optional. Override the public URL base when serving logos from a CDN or reverse proxy.
# Defaults to ${S3_ENDPOINT}/${S3_BUCKET}.
# S3_PUBLIC_URL_BASE=https://cdn.example.com/queue-logos

# 32+ char secret for signed QR tokens on the display page.
QR_TOKEN_SECRET=change_me_to_a_32_plus_char_random_string_xxxx

# 32+ char secret for host session JWTs.
HOST_JWT_SECRET=change_me_to_a_32_plus_char_random_string_yyyy

# Comma-separated list of admin emails allowed to sign in via magic link.
ADMIN_EMAILS=admin@example.com

# 16+ char secret for NextAuth.
NEXTAUTH_SECRET=change_me_to_a_16_plus_char_random_string
# Public base URL for NextAuth callbacks. Must match where the app is served.
NEXTAUTH_URL=http://localhost:3000

# Resend API key for magic-link delivery. Use re_test_xxx in CI; no real send.
RESEND_API_KEY=re_dev_placeholder
